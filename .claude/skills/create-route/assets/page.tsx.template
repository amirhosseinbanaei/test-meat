};

export default async function {{COMPONENT_NAME}}({
  params,
  searchParams,
}: PageProps) {
  const _params = await params;
  const _searchParams = await searchParams;

  return (
    <main>
      <h1>{{ROUTE_LABEL}}</h1>
      {/* Replace with real content. Server-side data fetching happens here. */}
