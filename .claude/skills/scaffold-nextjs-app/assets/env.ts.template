import { createEnv } from '@t3-oss/env-nextjs';
import { z } from 'zod';

/**
 * Typed environment variables.
 *
 * Rules:
 * - `server` keys are server-only. Trying to read them in a Client Component throws.
 * - `client` keys MUST be prefixed `NEXT_PUBLIC_` and will be inlined into the
 *   client bundle. Never put secrets here.
 * - Both are validated at build time. A missing or malformed value fails the build.
 */
export const env = createEnv({
  server: {
    // Backend API base URL (server-side fetches and Server Actions).
    BACKEND_API_URL: z.string().url(),

    // Secret used to sign / verify session cookies.
    // 32+ random bytes, base64- or hex-encoded.
    SESSION_SECRET: z.string().min(32),

    // Add more server-only vars here.
  },

  client: {
    // Backend API base URL exposed to the client (for client-side fetches).
    // Often the same value as BACKEND_API_URL when both share a public origin.
    NEXT_PUBLIC_BACKEND_API_URL: z.string().url(),

    // Add more `NEXT_PUBLIC_*` vars here.
  },

  // The runtime values. Use `process.env.X` for each one — t3-env reads them
  // statically so Next.js can inline `NEXT_PUBLIC_*` at build time.
  runtimeEnv: {
    BACKEND_API_URL: process.env.BACKEND_API_URL,
    SESSION_SECRET: process.env.SESSION_SECRET,
    NEXT_PUBLIC_BACKEND_API_URL: process.env.NEXT_PUBLIC_BACKEND_API_URL,
  },

  // Treat empty strings as undefined — common gotcha in deployment platforms
  // that emit `KEY=` for unset vars.
  emptyStringAsUndefined: true,
});
