'use server';

/**
 * Logout Server Action.
 *
 * Calls the backend's logout endpoint (so server-side session state is cleared
 * for that refresh token), then clears the local cookies, then redirects.
 *
 * Best-effort: if the backend call fails, we still clear cookies and redirect.
 * The user expects logout to "work" even if the network is bad.
 */

import { redirect } from 'next/navigation';
import { clearSession, getRefreshToken } from '@/common/services/session';
import { backendFetch } from '@/common/services/api-client';

export async function logout(): Promise<void> {
  const refreshToken = await getRefreshToken();

  if (refreshToken) {
    try {
      await backendFetch('/auth/logout', {
        method: 'POST',
        json: { refreshToken },
        noRefresh: true, // no point retrying on 401 — we're logging out anyway
      });
    } catch {
      // Best-effort. Always proceed to clearing local cookies.
    }
  }

  await clearSession();
  redirect('/login');
}
