/**
 * Session cookie helpers.
 *
 * We store two HTTP-only cookies issued by the separate backend:
 *   - `access_token`  — short-lived JWT used to authorise backend calls.
 *   - `refresh_token` — long-lived token used to mint a new access token.
 *
 * Rules:
 *   - HTTP-only: not readable from JavaScript on the client. JS code cannot
 *     leak the token even if XSS lands.
 *   - Secure: only sent over HTTPS in production.
 *   - SameSite=Lax: blocks CSRF on cross-site POSTs while letting top-level
 *     navigations work. If your backend requires SameSite=Strict, tighten it.
 *   - `path: '/'`: cookies are available on every route.
 */

import { cookies } from 'next/headers';
import { decodeJwt } from 'jose';

export const ACCESS_TOKEN_COOKIE = 'access_token';
export const REFRESH_TOKEN_COOKIE = 'refresh_token';

type TokenPair = {
  accessToken: string;
  refreshToken: string;
  /** Access-token expiry in seconds since epoch. Defaults to JWT `exp` if unset. */
  expiresAt?: number;
};

/**
 * Set both cookies after a successful login or refresh.
 * Called only from Server Actions / Route Handlers.
 */
export async function setSession({ accessToken, refreshToken, expiresAt }: TokenPair): Promise<void> {
  const cookieStore = await cookies();
  const isProd = process.env.NODE_ENV === 'production';

  // Derive the access-token's max-age from its JWT exp claim if not provided.
  let accessMaxAge: number | undefined;
  if (expiresAt) {
    accessMaxAge = Math.max(0, expiresAt - Math.floor(Date.now() / 1000));
  } else {
    try {
      const { exp } = decodeJwt(accessToken);
      if (typeof exp === 'number') {
        accessMaxAge = Math.max(0, exp - Math.floor(Date.now() / 1000));
      }
    } catch {
      // If the token isn't a JWT, fall back to session-only cookie (no maxAge).
    }
  }

  cookieStore.set(ACCESS_TOKEN_COOKIE, accessToken, {
    httpOnly: true,
    secure: isProd,
    sameSite: 'lax',
    path: '/',
    ...(accessMaxAge !== undefined ? { maxAge: accessMaxAge } : {}),
  });

  // Refresh token: longer-lived; 30 days is a sensible default. Adjust to
  // match the backend's refresh-token lifetime.
  cookieStore.set(REFRESH_TOKEN_COOKIE, refreshToken, {
    httpOnly: true,
    secure: isProd,
    sameSite: 'lax',
    path: '/',
    maxAge: 60 * 60 * 24 * 30,
  });
}

/**
 * Read the access token (if any).
 * Used by the api-client to attach an Authorization header.
 */
export async function getAccessToken(): Promise<string | null> {
  const cookieStore = await cookies();
  return cookieStore.get(ACCESS_TOKEN_COOKIE)?.value ?? null;
}

/**
 * Read the refresh token (if any).
 * Used only by the refresh flow.
 */
export async function getRefreshToken(): Promise<string | null> {
  const cookieStore = await cookies();
  return cookieStore.get(REFRESH_TOKEN_COOKIE)?.value ?? null;
}

/**
 * Clear both cookies. Called on logout or hard auth failures.
 */
export async function clearSession(): Promise<void> {
  const cookieStore = await cookies();
  cookieStore.delete(ACCESS_TOKEN_COOKIE);
  cookieStore.delete(REFRESH_TOKEN_COOKIE);
}

/**
 * Quick predicate — "is there at least an access token cookie?"
 * NOT a security check. The token may be expired or invalid; only the backend
 * decides if it's authorisedy. Used for cheap render-time branching.
 */
export async function hasSession(): Promise<boolean> {
  return (await getAccessToken()) !== null;
}
