'use client';

import { useEffect, useRef, type DependencyList, type EffectCallback } from 'react';

/**
 * Like `useEffect`, but skips the FIRST render — runs only on subsequent
 * dependency changes.
 *
 *   useUpdateEffect(() => {
 *     // Fires when `filter` changes, NOT on mount.
 *     refetch();
 *   }, [filter]);
 *
 * Useful for "react to user input changes" patterns where the initial mount
 * shouldn't fire the side effect.
 */
export function useUpdateEffect(effect: EffectCallback, deps?: DependencyList): void {
  const isFirstRender = useRef(true);

  useEffect(() => {
    if (isFirstRender.current) {
      isFirstRender.current = false;
      return;
    }
    return effect();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, deps);
}
