'use client';

import { useRef } from 'react';
import { useGSAP } from '@gsap/react';
import { gsap, ScrollTrigger } from '@/common/lib/gsap-init';

/**
 * Pattern: a scroll-driven section with a timeline. Replace contents to fit
 * the actual design. The wrapping div is the GSAP scope — all `gsap.from`
 * targets are scoped to it via {scope: container}.
 *
 * matchMedia honors prefers-reduced-motion automatically — when on, the
 * reduceMotion branch runs (instant state) instead of the animation.
 */

export function {{SectionName}}() {
  const container = useRef<HTMLElement>(null);

  useGSAP(
    () => {
      const mm = gsap.matchMedia();

      mm.add(
        {
          isDesktop: '(min-width: 769px)',
          isMobile: '(max-width: 768px)',
          reduceMotion: '(prefers-reduced-motion: reduce)',
        },
        (context) => {
          const { reduceMotion } = context.conditions!;

          if (reduceMotion) {
            // No animation — set final state immediately.
            gsap.set('.fade-in', { opacity: 1, y: 0 });
            return;
          }

          const tl = gsap.timeline({
            scrollTrigger: {
              trigger: container.current,
              start: 'top center',
              end: 'bottom center',
              scrub: 1,
            },
          });

          tl.from('.fade-in', {
            y: 50,
            opacity: 0,
            stagger: 0.1,
            duration: 1,
            ease: 'power3.out',
          });

          // Cleanup is handled automatically by useGSAP + ScrollTrigger.
        },
      );
    },
    { scope: container },
  );

  return (
    <section ref={container} className="py-24">
      <h2 className="fade-in text-4xl font-bold">Heading</h2>
      <p className="fade-in mt-4">Body</p>
      <div className="fade-in mt-8">Footer</div>
    </section>
  );
}
